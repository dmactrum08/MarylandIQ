# MarylandIQ — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ---------------------------------------------------------------------------
# Supabase
# Get these from: https://app.supabase.com → your project → Settings → API
# ---------------------------------------------------------------------------

# Your Supabase project URL (e.g. https://abcdefghijkl.supabase.co)
SUPABASE_URL=

# Service role key — used by pipeline scripts (bypasses RLS, writes to DB)
# Found under: Settings → API → Project API keys → service_role
# Keep this secret — never expose it in frontend code or public repos
SUPABASE_SERVICE_ROLE_KEY=

# Anon key — used by the Next.js frontend for read-only ballot lookup
# Found under: Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Google AI Studio (Gemini)
# Get a free API key at: https://aistudio.google.com/app/apikey
# No billing account required. Free tier: 1,000 requests/day, 15 req/min.
# Used by: enrich_candidates.py (Stage 2+)
# ---------------------------------------------------------------------------
GOOGLE_AI_STUDIO_API_KEY=

# ---------------------------------------------------------------------------
# Vercel Deploy Hook
# Get this from: Vercel → your project → Settings → Git → Deploy Hooks
# Create a hook named "pipeline-trigger" on the main branch.
# Used by: trigger_build.py (Stage 5)
# ---------------------------------------------------------------------------
VERCEL_DEPLOY_HOOK_URL=

# ---------------------------------------------------------------------------
# Withdrawal alert email
# Used by: detect_withdrawals.py (Stage 5)
# Use a Gmail address with an App Password (not your main password).
# Generate an App Password at: https://myaccount.google.com/apppasswords
# ---------------------------------------------------------------------------
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
GMAIL_APP_PASSWORD=

# ---------------------------------------------------------------------------
# OpenRouter (alternative AI backend)
# Get a free API key at: https://openrouter.ai/keys
# Used by: any pipeline script with --backend openrouter
# OPENROUTER_MODEL defaults to google/gemini-2.0-flash-exp:free if not set.
# Browse available models at: https://openrouter.ai/models
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# ---------------------------------------------------------------------------
# LM Studio (local AI backend)
# Run LM Studio locally and enable the local server at http://localhost:1234
# OPENAI-compatible API — use any model loaded in LM Studio.
# Used by: any pipeline script with --backend lmstudio
# ---------------------------------------------------------------------------
LM_STUDIO_MODEL=local-model

# ---------------------------------------------------------------------------
# Maryland Campaign Finance committee CSV
# Download from: campaignfinance.maryland.gov/public/cf/downloads → "Committee" file
# If not set, the pipeline looks for docs/finance/Committee Download*.csv automatically.
# Refresh this file periodically — it reflects the state of filings as of download date.
# ---------------------------------------------------------------------------
COMMITTEE_CSV_PATH=

# ---------------------------------------------------------------------------
# Serper (Google Search API) — primary search provider for thin-candidate discovery
# Sign up at: https://serper.dev — free tier: 2,500 queries.
# Used by: discover_thin_candidates.py (Stage 2)
# ---------------------------------------------------------------------------
SERPER_API_KEY=

# ---------------------------------------------------------------------------
# Brave Search API — fallback search provider if Serper is unavailable/empty
# Sign up at: https://api-dashboard.search.brave.com
# Free tier: 2,000 queries/month.
# Used by: discover_thin_candidates.py (Stage 2, fallback only)
# ---------------------------------------------------------------------------
BRAVE_SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Twitter/X API (optional — Stage 2, thin-candidate social inference)
# Free tier: 500 reads/month. Only used as last resort in the social pipeline.
# Get a key at: https://developer.twitter.com
# If you decide to skip Twitter for MVP, leave these blank.
# ---------------------------------------------------------------------------
TWITTER_BEARER_TOKEN=

# ---------------------------------------------------------------------------
# Stripe (donations)
# Get your keys at: https://dashboard.stripe.com → Developers → API keys
# Use sk_test_... during development, sk_live_... in production.
# Also set in frontend/.env.local for the Next.js app.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — used to verify webhook payloads from Stripe.
# Get this from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# For local testing: use the Stripe CLI → `stripe listen` outputs a whsec_... secret
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Resend (email notifications for reports)
# Sign up at: https://resend.com — free tier: 3,000 emails/month
# After signing up, verify your domain (marylandiq.org) under Domains.
# Then create an API key under API Keys.
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# The public URL of the site — used for Stripe success/cancel redirect URLs.
# In development: http://localhost:3000
# In production: https://marylandiq.com
NEXT_PUBLIC_SITE_URL=
